# ===============================
# Application
# ===============================
APP_NAME=llm-inference-platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ===============================
# Security
# ===============================
SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY_HEADER=X-API-Key
# Provider API keys (fill in your real keys)
# Hugging Face: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here
# Groq: https://console.groq.com/keys
GROQ_API_KEY=groq_your_api_key_here

# ===============================
# Database
# ===============================
# Native local: sqlite+aiosqlite:///./llm_gateway.db
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/llm_gateway
DATABASE_URL=sqlite+aiosqlite:///./llm_gateway.db

# ===============================
# Redis
# ===============================
# Native local: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ===============================
# Model Storage
# ===============================
MODEL_DIR=./data/models
DEFAULT_MODEL=mistral-7b-instruct

# ===============================
# GPU / Runtime
# ===============================
USE_GPU=true
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_SECONDS=120

# ===============================
# Observability
# ===============================
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
LOG_LEVEL=INFO

# ===============================
# Billing
# ===============================
ENABLE_BILLING=false
TOKEN_COST_PER_1K=0.002